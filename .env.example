# DiscoBall portable Docker configuration
# Copy this file to .env and edit values for your host.
# Do not commit .env.

# Required for OMDb metadata lookup.
# Get a key from https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=put-your-key-here

# Host paths. These are examples; change them for your Docker host.
# Linux/NAS example:
# DISCOBALL_WATCH_PATH=/srv/media/incoming
# DISCOBALL_OUTPUT_PATH=/srv/media/library
# DISCOBALL_CONFIG_PATH=/srv/discoball/config

# Local test defaults:
DISCOBALL_WATCH_PATH=./watch
DISCOBALL_OUTPUT_PATH=./output
DISCOBALL_CONFIG_PATH=./config

# Web UI host port. Container UI port remains 8000.
DISCOBALL_WEB_PORT=8000

# General runtime options
DISCOBALL_CONTAINER_NAME=discoball
SOURCE_TAG_DEFAULT=DVD
PROVIDERS=omdb,imdb
IMDB_SQLITE_PATH=/config/imdb.sqlite
UI_ENABLED=1
UI_PORT=8000
LOG_LEVEL=INFO

# Watch/stability behavior
STABLE_TIME_SECONDS=120
CHECK_INTERVAL_SECONDS=30
VIDEO_EXTENSIONS=mkv,mp4
MIN_VIDEO_SIZE_MB=50
MIN_CONFIDENCE=0.64

# Naming/output behavior
INCLUDE_GENRE_TAG=1
INCLUDE_SOURCE_TAG=1
MOVIE_ROOT_SUBDIR=
TV_ROOT_SUBDIR=
UNMATCHED_SUBDIR=_Unmatched
FILE_ACTION=move
CONFLICT_POLICY=suffix
NAMING_STYLE=discoball
